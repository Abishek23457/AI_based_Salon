# ─── Environment Configuration Example ───────────────────────────────────────
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git - it's in .gitignore for a reason!

# ─── Environment Mode ──────────────────────────────────────────────────────────
# Set to "production" to enable security features (HTTPS, strict CORS, etc.)
ENVIRONMENT=development

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite for local development (default)
DATABASE_URL=sqlite:///./booksmart.db

# PostgreSQL for production (uncomment and configure)
# DATABASE_URL=postgresql://username:password@localhost:5432/booksmart_ai

# ─── Exotel SMS & Voice ──────────────────────────────────────────────────────
# Get these from https://my.exotel.com/
EXOTEL_ACCOUNT_SID=your_account_sid_here
EXOTEL_API_KEY=your_api_key_here
EXOTEL_API_TOKEN=your_api_token_here
EXOTEL_APP_ID=your_app_id_here
EXOTEL_PHONE_NUMBER=+91XXXXXXXXXX

# ─── AI / LLM ──────────────────────────────────────────────────────────────────
# Get from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Voice: Speech-to-Text & Text-to-Speech ───────────────────────────────────

# Get from Google Cloud Console
GOOGLE_TTS_API_KEY=your_google_tts_key_here

# ─── JWT Authentication ────────────────────────────────────────────────────────
# Generate a strong random key (32+ characters)
# python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your_super_secret_random_key_here_min_32_chars

# ─── Razorpay Payments ─────────────────────────────────────────────────────────
# Get from https://dashboard.razorpay.com/
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ─── Email Notifications (Gmail SMTP) ──────────────────────────────────────────
# Use app-specific password, not your Gmail password!
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password

# ─── Security Settings ─────────────────────────────────────────────────────────
# Enable to log all security events
SECURITY_LOG_LEVEL=INFO

# Allowed IPs for webhook access (comma-separated, optional)
# WEBHOOK_ALLOWED_IPS=14.141.14.0/24,115.110.0.0/16
